{
  "plugins": [
    {
      "name": "classification",
      "enabled": true,
      "tasks": ["classification"],
      "weight": 1.0,
      "config": {
        "model": "openai/clip-vit-base-patch32",
        "device": "auto",
        "labels": ["person", "animal", "vehicle", "document", "indoor", "outdoor"],
        "top_k": 3
      }
    },
    {
      "name": "grounding_dino",
      "enabled": true,
      "tasks": ["object_detection"],
      "weight": 1.2,
      "config": {
        "model": "IDEA-Research/grounding-dino-base",
        "device": "auto",
        "box_threshold": 0.35,
        "text_threshold": 0.25
      }
    },
    {
      "name": "grounded_sam2",
      "enabled": true,
      "tasks": ["segmentation"],
      "weight": 1.5,
      "config": {
        "grounding_model": "IDEA-Research/grounding-dino-base",
        "sam_backend": "ultralytics_sam2",
        "sam_model": "sam2_b.pt",
        "device": "auto",
        "box_threshold": 0.35,
        "text_threshold": 0.25,
        "mask_threshold": 0.5
      }
    },
    {
      "name": "sam",
      "enabled": false,
      "tasks": ["segmentation"],
      "weight": 1.0,
      "config": {
        "backend": "ultralytics_sam2",
        "model": "sam2_b.pt",
        "device": "auto"
      }
    },
    {
      "name": "pose",
      "enabled": true,
      "tasks": ["pose_estimation"],
      "weight": 1.0,
      "config": {
        "model": "yolo11n-pose.pt",
        "device": "auto",
        "keypoint_threshold": 0.25
      }
    },
    {
      "name": "ocr",
      "enabled": true,
      "tasks": ["ocr"],
      "weight": 1.0,
      "config": {
        "backend": "paddleocr",
        "lang": "korean",
        "languages": ["ko", "en"],
        "gpu": "auto"
      }
    },
    {
      "name": "tracking",
      "enabled": true,
      "tasks": ["tracking"],
      "weight": 1.0,
      "config": {
        "model": "yolo11n.pt",
        "tracker": "bytetrack.yaml",
        "device": "auto"
      }
    }
  ]
}
