AWS_REGION=us-east-1

# Optional boto3 credential sources supported by the desktop/web settings UI:
# AWS_PROFILE, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_SESSION_TOKEN

# Heterogeneous AWS Bedrock Claude cascade for the paper claim:
# low-capacity draft model -> high-capacity verification model.
LOW_MODEL=bedrock:us.anthropic.claude-haiku-4-5-20251001-v1:0
HIGH_MODEL=bedrock:us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Optional natural-language workflow planner. Falls back to LOW_MODEL.
# PLANNER_MODEL=bedrock:us.anthropic.claude-haiku-4-5-20251001-v1:0

# Alternative raw Bedrock IDs are also supported:
# AWS_BEDROCK_LOW_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
# AWS_BEDROCK_HIGH_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Direct provider examples, not needed when using Bedrock:
# OPENAI_API_KEY=your_openai_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key
